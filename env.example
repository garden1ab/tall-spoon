# Optional: Hugging Face token, useful if the model license requires login/acceptance.
# Create a token at Hugging Face and accept the Krea-2 model license first.
HF_TOKEN=

# Optional: explicit checkpoint paths inside the container.
# Defaults are /workspace/checkpoints/turbo.safetensors and /workspace/checkpoints/raw.safetensors.
OSS_TURBO=/workspace/checkpoints/turbo.safetensors
OSS_RAW=/workspace/checkpoints/raw.safetensors

# UI/network settings
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# Storage
HF_HOME=/workspace/.cache/huggingface
OUTPUT_DIR=/workspace/outputs
CHECKPOINT_DIR=/workspace/checkpoints

# Runtime
KREA2_DEVICE=cuda
KREA2_DTYPE=bfloat16

# Memory/stability defaults for CUDA + WSL2.
# Keep only one large Krea-2 pipeline in VRAM.
KREA2_MAX_CACHED_PIPELINES=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
CUDA_MODULE_LOADING=LAZY
TORCHINDUCTOR_CACHE_DIR=/workspace/.cache/torchinductor
