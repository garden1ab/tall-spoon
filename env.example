# Optional Hugging Face token. Use this only for the one-time online prep service
# after accepting the Krea/Qwen model licenses if required.
HF_TOKEN=

# Runtime is hard-offline by default. Leave this at 1 for normal use.
# Generate will fail fast if files are missing instead of trying URL downloads.
KREA2_OFFLINE_MODE=1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1

# Optional explicit checkpoint paths inside the container.
OSS_TURBO=/workspace/checkpoints/turbo.safetensors
OSS_RAW=/workspace/checkpoints/raw.safetensors

# Local text encoder snapshot path. The one-time prep service downloads
# Qwen/Qwen3-VL-4B-Instruct into this directory.
MODEL_DIR=/workspace/models
KREA2_TEXT_ENCODER_REPO=Qwen/Qwen3-VL-4B-Instruct
KREA2_TEXT_ENCODER_PATH=/workspace/models/Qwen-Qwen3-VL-4B-Instruct
KREA2_VAE_REPO=Qwen/Qwen-Image
KREA2_VAE_PATH=/workspace/models/Qwen-Qwen-Image

# One-time model preparation selection. Default: Turbo + text encoder.
# RAW is also large and is off by default for 16 GB GPUs.
KREA2_PREP_TEXT_ENCODER=1
KREA2_PREP_VAE=1
KREA2_PREP_TURBO=1
KREA2_PREP_RAW=0
KREA2_PREP_ALL=0

# UI/network settings. Published only on localhost by docker-compose.yml.
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860

# Storage
HF_HOME=/workspace/.cache/huggingface
OUTPUT_DIR=/workspace/outputs
CHECKPOINT_DIR=/workspace/checkpoints

# Runtime
KREA2_DEVICE=cuda
KREA2_DTYPE=bfloat16

# Memory/stability defaults for CUDA + WSL2.
KREA2_MAX_CACHED_PIPELINES=1
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
CUDA_MODULE_LOADING=LAZY
TORCHINDUCTOR_CACHE_DIR=/workspace/.cache/torchinductor

# Set to 1 to disable torch.compile. This can make first-run behavior simpler,
# but repeated generations are usually slower than compiled mode.
KREA2_DISABLE_TORCH_COMPILE=0
